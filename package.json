{
  "name": "chess-theory-app",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "predev": "tsx scripts/build-openings.ts",
    "prebuild": "tsx scripts/build-openings.ts",
    "pregenerate": "tsx scripts/build-openings.ts",
    "build:openings": "tsx scripts/build-openings.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/ui": "4.6.1",
    "chess.js": "^1.4.0",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue3-chessboard": "^1.3.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "4.0.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  }
}
